//@version=5
strategy("VividStrategy", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, currency=currency.USD)

// --- Inputs ---
src = input(close, title="Source")
risk_percent = input.float(1.0, title="Risk Per Trade (%)", minval=0.1, maxval=10.0)

